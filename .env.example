# ─── Telegram ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Authorized Telegram user_ids. Format: id:Name,id:Name
# Get your ID from @userinfobot. Leave empty to allow anyone (local testing only!).
ALLOWED_USER_IDS=123456789:Mario

# ─── Claude Code CLI ───────────────────────────────────────────────────────────

# Root directory boundary. /cd and /set workdir can only change inside this.
BASEDIR=/home/user/projects

# Default working directory (must be inside BASEDIR)
WORKDIR=/home/user/projects

# Max seconds for inline prompts (default 300)
CLAUDE_TIMEOUT_SECONDS=300

# Max seconds for background /task (default 1800 = 30 min)
CLAUDE_TASK_TIMEOUT_SECONDS=1800

# Extra paths prepended to PATH to find the claude executable
# (separated by ; on Windows, : on Linux/macOS)
#EXTRA_PATH=/usr/local/bin

# ─── Bedrock Authentication (optional) ─────────────────────────────────────────
# Uncomment if using Claude Code via Amazon Bedrock instead of direct Anthropic API.

#CLAUDE_CODE_USE_BEDROCK=1
#AWS_REGION=eu-central-1
#AWS_BEARER_TOKEN_BEDROCK=ABSK...
#ANTHROPIC_MODEL=arn:aws:bedrock:...
#ANTHROPIC_DEFAULT_SONNET_MODEL=arn:aws:bedrock:...
#ANTHROPIC_DEFAULT_OPUS_MODEL=arn:aws:bedrock:...

# ─── Localization ──────────────────────────────────────────────────────────────
#
# Language for voice transcription AND UI localization (ISO 639-1 code).
# Determines:
#   - Whisper transcription language hint
#   - Voice command aliases (e.g. "sessioni" for /sessions in Italian)
#   - Voice trigger words (e.g. "punto", "comando" in Italian)
#   - UI messages (errors, confirmations, labels)
#   - Safety detection patterns (localized danger words)
#
# Built-in locales: en, it, fr, de, es
# Custom locales: create ~/.telegram-bot/locales/{lang}.json
# Leave empty for English (no aliases, auto-detect transcription language).
WHISPER_LANGUAGE=en

# ─── Audio transcription ──────────────────────────────────────────────────────

# Comma-separated fallback chain. First success wins.
#   groq_whisper    → Groq Whisper API (fastest, requires GROQ_API_KEY)
#   openai_whisper  → OpenAI Whisper API (requires OPENAI_API_KEY)
#   faster_whisper  → local model (no key, slower first load)
TRANSCRIBER=openai_whisper,faster_whisper

# Required only if using groq_whisper (free at https://console.groq.com)
#GROQ_API_KEY=gsk_...

# Required only if using openai_whisper or openai_tts
#OPENAI_API_KEY=sk-...

# Not needed if CLAUDE_CODE_USE_BEDROCK=1 (uses AnthropicBedrock automatically)
#ANTHROPIC_API_KEY=sk-ant-...

# faster-whisper model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower and more RAM
FASTER_WHISPER_MODEL=base

# ─── Text-to-Speech ───────────────────────────────────────────────────────────

# Comma-separated fallback chain. First success wins.
#   openai_tts  → OpenAI TTS (requires OPENAI_API_KEY)
#   gtts        → Google TTS (free, no key)
TTS_PROVIDER=openai_tts,gtts

# OpenAI TTS voice: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=alloy

# OpenAI TTS model: tts-1 (fast), tts-1-hd (higher quality)
TTS_MODEL=tts-1

# ─── Webcam ───────────────────────────────────────────────────────────────────

# Video/audio device names. Leave empty for auto-detect.
# Windows: DirectShow names (e.g. "Integrated Camera")
# Linux: V4L2 device path (e.g. /dev/video0)
# macOS: AVFoundation device index or name
#WEBCAM_VIDEO_DEVICE=Integrated Camera
#WEBCAM_AUDIO_DEVICE=Microphone Array

# Capture resolution and framerate (must be supported by your webcam)
WEBCAM_RESOLUTION=1280x720
WEBCAM_FRAMERATE=30
